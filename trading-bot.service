[Unit]
Description=ETH Trading Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/trading-bot
Environment=PATH=/home/ubuntu/.local/bin:/usr/bin:/usr/local/bin
ExecStart=/usr/bin/python3 /opt/trading-bot/main_bot.py
Restart=always
RestartSec=10
StandardOutput=append:/opt/trading-bot/logs/service.log
StandardError=append:/opt/trading-bot/logs/error.log

[Install]
WantedBy=multi-user.target